{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://signaler.dev/schemas/v3-release-manifest.schema.json",
  "title": "V3ReleaseManifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "release",
    "assets",
    "gateReports",
    "environment"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "release": {
      "type": "object",
      "required": [
        "version",
        "channel",
        "gitCommit"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "channel": {
          "type": "string",
          "enum": [
            "rc",
            "ga",
            "patch",
            "canary"
          ]
        },
        "gitCommit": {
          "type": "string",
          "minLength": 7
        }
      },
      "additionalProperties": false
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "sizeBytes"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "gateReports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "warn",
              "error"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "environment": {
      "type": "object",
      "required": [
        "nodeVersion",
        "platform",
        "packageManager"
      ],
      "properties": {
        "nodeVersion": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "packageManager": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
