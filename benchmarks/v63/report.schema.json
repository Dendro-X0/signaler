{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://signaler.dev/schemas/v63-success-gate.schema.json",
  "title": "V63SuccessGateReport",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "status", "checks", "summary"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "generatedAt": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["ok", "warn", "error"] },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "details", "blocking"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["ok", "warn", "error"] },
          "details": { "type": "string", "minLength": 1 },
          "blocking": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["blockingFailures", "warnings", "manualItems"],
      "properties": {
        "blockingFailures": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "manualItems": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
